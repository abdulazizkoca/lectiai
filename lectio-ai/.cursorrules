# ══════════════════════════════════════════
# BLOK 1 — TEXNIK ARXITEKTURA
# ══════════════════════════════════════════

## Stack

```
┌─────────────────────────────────────────────────────────────┐
│                      FRONTEND LAYER                          │
│  Next.js 14 (App Router) + TypeScript strict                │
│  Tailwind CSS + Framer Motion + Zustand + React Query       │
│  Socket.io-client + Three.js + WebRTC (kamera)             │
└──────────────────────────┬──────────────────────────────────┘
                           │ REST + WebSocket + WebRTC
┌──────────────────────────▼──────────────────────────────────┐
│                      BACKEND LAYER                           │
│  Python FastAPI (async) + SQLAlchemy 2.0                    │
│  PostgreSQL 15 + Redis 7 + Celery                           │
│  Socket.io + Elasticsearch                                  │
└──────────┬───────────────┬──────────────────┬───────────────┘
           ▼               ▼                  ▼
      Claude API      OpenCV +            MinIO/S3
      (AI brain)      MediaPipe           (fayllar)
                      (kamera AI)
```

## Monorepo tuzilishi

```
lectio-ai/
├── apps/
│   ├── professor/          # Professor Hub (Next.js)
│   ├── quiz/               # Quiz Arena (Next.js)
│   └── student/            # Student Hub (Next.js)
├── packages/
│   ├── ui/                 # Shared UI components
│   ├── socket/             # Shared Socket.io logic
│   └── types/              # Shared TypeScript types
├── backend/
│   ├── routers/
│   ├── services/
│   ├── models/
│   └── ai/
└── docker-compose.yml
```

## Database Schema (To'liq)

```sql
-- FOYDALANUVCHILAR
CREATE TABLE users (
  id            SERIAL PRIMARY KEY,
  email         VARCHAR UNIQUE,
  full_name     VARCHAR,
  role          ENUM('professor','student','admin'),
  telegram_id   VARCHAR,
  avatar_url    VARCHAR,
  xp_points     INTEGER DEFAULT 0,
  streak_days   INTEGER DEFAULT 0,
  level         INTEGER DEFAULT 1,
  badges        JSONB DEFAULT '[]',
  settings      JSONB DEFAULT '{}',
  last_active   TIMESTAMP,
  created_at    TIMESTAMP DEFAULT NOW()
);

-- METODICHKALAR
CREATE TABLE materials (
  id            SERIAL PRIMARY KEY,
  title         VARCHAR,
  file_url      VARCHAR,
  file_type     VARCHAR,
  raw_text      TEXT,
  analysis      JSONB,
  processed     BOOLEAN DEFAULT FALSE,
  professor_id  INTEGER REFERENCES users(id),
  created_at    TIMESTAMP DEFAULT NOW()
);

-- DARSLAR
CREATE TABLE lessons (
  id                SERIAL PRIMARY KEY,
  title             VARCHAR,
  topic             VARCHAR,
  material_id       INTEGER REFERENCES materials(id),
  presentation_data JSONB,
  wow_fact          TEXT,
  summary_text      TEXT,
  audio_url         VARCHAR,
  duration_minutes  INTEGER,
  professor_id      INTEGER REFERENCES users(id),
  is_template       BOOLEAN DEFAULT FALSE,
  use_count         INTEGER DEFAULT 0,
  scheduled_at      TIMESTAMP,
  created_at        TIMESTAMP DEFAULT NOW()
);

-- LIVE SESSIYALAR
CREATE TABLE live_sessions (
  id            SERIAL PRIMARY KEY,
  room_code     VARCHAR(8) UNIQUE,
  lesson_id     INTEGER REFERENCES lessons(id),
  professor_id  INTEGER REFERENCES users(id),
  status        ENUM('waiting','active','paused','ended'),
  config        JSONB,     -- rejim, sozlamalar
  started_at    TIMESTAMP,
  ended_at      TIMESTAMP,
  created_at    TIMESTAMP DEFAULT NOW()
);

-- ISHTIROKCHILAR
CREATE TABLE session_participants (
  id          SERIAL PRIMARY KEY,
  session_id  INTEGER REFERENCES live_sessions(id),
  student_id  INTEGER REFERENCES users(id),
  nickname    VARCHAR,
  score       INTEGER DEFAULT 0,
  team        VARCHAR,    -- jamoaviy rejim uchun
  joined_at   TIMESTAMP DEFAULT NOW()
);

-- SAVOLLAR
CREATE TABLE questions (
  id            SERIAL PRIMARY KEY,
  lesson_id     INTEGER REFERENCES lessons(id),
  material_id   INTEGER REFERENCES materials(id),
  question      TEXT,
  type          ENUM('multiple_choice','true_false','short_answer','image_choice','fill_blank','ordering','matching'),
  options       JSONB,
  correct       VARCHAR,
  explanation   TEXT,
  difficulty    ENUM('easy','medium','hard'),
  time_limit    INTEGER DEFAULT 20,
  points        INTEGER DEFAULT 100,
  image_url     VARCHAR,
  tags          TEXT[],
  created_at    TIMESTAMP DEFAULT NOW()
);

-- JAVOBLAR
CREATE TABLE answers (
  id            SERIAL PRIMARY KEY,
  session_id    INTEGER REFERENCES live_sessions(id),
  question_id   INTEGER REFERENCES questions(id),
  student_id    INTEGER REFERENCES users(id),
  answer        VARCHAR,
  is_correct    BOOLEAN,
  time_taken    INTEGER,
  points_earned INTEGER,
  answered_at   TIMESTAMP DEFAULT NOW()
);

-- FLASHCARDLAR (Spaced Repetition)
CREATE TABLE flash_cards (
  id            SERIAL PRIMARY KEY,
  question      TEXT,
  answer        TEXT,
  hint          TEXT,
  difficulty    FLOAT DEFAULT 2.5,
  interval      INTEGER DEFAULT 1,
  repetitions   INTEGER DEFAULT 0,
  ease_factor   FLOAT DEFAULT 2.5,
  next_review   TIMESTAMP DEFAULT NOW(),
  lesson_id     INTEGER REFERENCES lessons(id),
  student_id    INTEGER REFERENCES users(id),
  subject       VARCHAR,
  tags          TEXT[]
);

-- DIQQAT TAHLILI (kamera — faqat aggregate)
CREATE TABLE attention_logs (
  id              SERIAL PRIMARY KEY,
  session_id      INTEGER REFERENCES live_sessions(id),
  attention_avg   FLOAT,
  distracted_pct  FLOAT,
  phone_usage_pct FLOAT,
  talking_pct     FLOAT,
  absent_pct      FLOAT,
  confusion_score FLOAT,
  timestamp       TIMESTAMP DEFAULT NOW()
  -- MUHIM: Individual ma'lumot SAQLANMAYDI — faqat umumiy foiz
);

-- O'QUVCHI PROGRESS
CREATE TABLE student_progress (
  id              SERIAL PRIMARY KEY,
  student_id      INTEGER REFERENCES users(id),
  subject         VARCHAR,
  topic           VARCHAR,
  mastery_level   FLOAT DEFAULT 0,   -- 0-100
  sessions_count  INTEGER DEFAULT 0,
  last_studied    TIMESTAMP,
  weak_points     JSONB DEFAULT '[]',
  strong_points   JSONB DEFAULT '[]'
);

-- ACHIEVEMENT TIZIMI
CREATE TABLE achievements (
  id          SERIAL PRIMARY KEY,
  code        VARCHAR UNIQUE,
  title       VARCHAR,
  description TEXT,
  icon        VARCHAR,
  xp_reward   INTEGER,
  condition   JSONB
);

CREATE TABLE user_achievements (
  id             SERIAL PRIMARY KEY,
  user_id        INTEGER REFERENCES users(id),
  achievement_id INTEGER REFERENCES achievements(id),
  earned_at      TIMESTAMP DEFAULT NOW()
);

-- PEER LEARNING (Student Hub)
CREATE TABLE study_groups (
  id          SERIAL PRIMARY KEY,
  name        VARCHAR,
  subject     VARCHAR,
  creator_id  INTEGER REFERENCES users(id),
  members     INTEGER[],
  is_public   BOOLEAN DEFAULT TRUE,
  created_at  TIMESTAMP DEFAULT NOW()
);

CREATE TABLE peer_questions (
  id          SERIAL PRIMARY KEY,
  asker_id    INTEGER REFERENCES users(id),
  question    TEXT,
  subject     VARCHAR,
  topic       VARCHAR,
  upvotes     INTEGER DEFAULT 0,
  is_answered BOOLEAN DEFAULT FALSE,
  created_at  TIMESTAMP DEFAULT NOW()
);

CREATE TABLE peer_answers (
  id          SERIAL PRIMARY KEY,
  question_id INTEGER REFERENCES peer_questions(id),
  answerer_id INTEGER REFERENCES users(id),
  answer      TEXT,
  upvotes     INTEGER DEFAULT 0,
  is_accepted BOOLEAN DEFAULT FALSE,
  created_at  TIMESTAMP DEFAULT NOW()
);
```

