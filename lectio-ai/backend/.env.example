# PostgreSQL Connection (psycopg2 — synchronous driver)
DATABASE_URL=postgresql://lectio:secure_password@localhost:5432/lectio_db
# SQLite for local development (default):
# DATABASE_URL=sqlite:///./lectio.db

# Redis Connection (Cache, Celery, Socket.io)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# AI and Services
GEMINI_API_KEY=your_gemini_api_key_here
SENTRY_DSN=your_sentry_dsn_here

# JWT Configuration
SECRET_KEY=your_super_secret_jwt_key_at_least_32_characters_long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Frontend Config
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
